{
  "name": "@ledgerproof/browser-extension",
  "version": "1.0.0",
  "description": "LedgerProof Verifier — Chrome/Firefox/Safari extension that surfaces a verification badge on any web page with a data-lpr-receipt attribute.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && cp -r public/* dist/",
    "build:firefox": "WEB_EXT_TARGET=firefox vite build",
    "build:safari": "WEB_EXT_TARGET=safari vite build"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@ledgerproof/sdk": "^1.0.0",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/firefox-webext-browser": "^120.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
