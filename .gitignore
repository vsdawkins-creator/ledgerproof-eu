~/.ledgerproof-secrets/
.env
.env.*
!.env.example
*.dmg

# TypeScript SDK build artifacts (regenerated by npm run build)
sdks/*/node_modules/
sdks/*/dist/
clients/*/node_modules/
clients/*/dist/

# Python (gtm-code + api-backend)
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/
**/.coverage
**/coverage.xml
**/htmlcov/
**/.venv/
**/venv/
10-gtm-code/.venv/
10-gtm-code/.pytest_cache/
10-gtm-code/.coverage
13-api-backend/.venv/
13-api-backend/__pycache__/

# Local SQLite databases used by gtm-code
**/state.db
**/state.db-journal

# PyPI publish build artifacts (regenerated by tools/pypi-publish/publish-all.sh)
tools/pypi-publish/dist/
tools/pypi-publish/publish.log

# PDF generator scratch outputs (final PDFs intended for distribution go in their target dirs)
tools/pdf-generator/out/

# Astro Starlight build cache
clients/docs-site/dist/
clients/docs-site/.astro/

# Chrome headless cache from md_to_pdf.py
.org.chromium.Chromium*/

# Session-scoped secrets (never persist to git)
.lpr-session-token-do-not-commit
*.token
*.key
*.pem
!*.pub.pem

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
sdks/typescript/*.tgz
sdks/python/dist/
